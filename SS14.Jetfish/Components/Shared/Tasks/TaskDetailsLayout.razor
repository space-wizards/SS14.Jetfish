@using SS14.Jetfish.Components.Shared.Markdown
<div style="display:contents;">
<MudDialog ContentClass="pa-0 ma-0" Style="height: 78vh; width: 100%">
    <DialogContent>
        <MudStack Class="height-full" StretchItems="StretchItems.All" Row="true" Spacing="0">
            <MudPaper Elevation="0" Width="60%">
                <MudStack Row="true" Class="content-box height-8 px-4 pt-1 width-full border-b border-color-default">
                    <TaskSectionSelect></TaskSectionSelect>
                </MudStack>
                <MudStack Class="pa-4">
                    <p>editor</p>
                </MudStack>
            </MudPaper>
            <MudPaper Width="40%" Class="mud-theme-dark rounded-l-0 height-full" Elevation="0">
                <MudStack Spacing="0" Class="height-full">
                    <MudText Class="px-4 pt-2 pb-5" Typo="Typo.subtitle2">Comments:</MudText>
                    <MudStack class="overflow-y-auto flex-grow-1" Style="height: calc(100% - 60px);">
                        @foreach (var comment in TaskDetails?.Comments ?? [])
                        {
                            <TaskComment
                                Comment="comment"
                                Class="@("width-full px-4 border-b " + (CurrentlyEditedComment?.Id == comment.Id ? "border-color-highlight" : "border-color-default"))"
                                IsBeingEdited="@(CurrentlyEditedComment?.Id == comment.Id)"
                                OnEdit="async value => await StartEditingComment(value)"/>
                        }
                    </MudStack>
                    <MarkdownEditor
                        @ref="_editor"
                        OnSave="text => SaveComment(text)"
                        OnCancel="@CancelEditingComment"
                        Class="ma-2"
                        Text="@CurrentEditorText"/>
                </MudStack>
            </MudPaper>
        </MudStack>
    </DialogContent>
</MudDialog>
</div>

